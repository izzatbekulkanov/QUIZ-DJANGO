# Django
DJANGO_SECRET_KEY=replace-with-a-real-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,test.namspi.uz,webtest.namspi.uz
DJANGO_CSRF_TRUSTED_ORIGINS=https://test.namspi.uz,http://test.namspi.uz,https://webtest.namspi.uz,http://webtest.namspi.uz
USE_X_FORWARDED_HOST=True

# Database
DJANGO_DB_ENGINE=django.db.backends.sqlite3
DJANGO_DB_NAME=db.sqlite3
# DJANGO_DB_USER=
# DJANGO_DB_PASSWORD=
# DJANGO_DB_HOST=localhost
# DJANGO_DB_PORT=5432

# Email
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Security
SESSION_COOKIE_AGE=600
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_SSL_REDIRECT=False
 